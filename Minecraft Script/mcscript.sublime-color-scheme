      "scope":"mcs.core.array.byte",
      "foreground":"hsl(30, 75%, 70%)",
      "font_style":"italic"
    },
    {
      "scope":"mcs.core.array.int",
      "foreground":"hsl(200, 100%, 65%)",
      "font_style":"italic"
