    {
      "scope":"mcs.core.bool.true",
      "foreground":"hsl(130, 80%, 60%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.core.bool.false",
      "foreground":"hsl(355, 100%, 65%)",
      "font_style":"italic"
    },
    {
      "scope":"mcs.core.numbers",
      //"foreground":"hsl(130, 50%, 70%)",
      //"foreground":"hsl(110, 100%, 65%)",
      "foreground":"hsl(40, 100%, 75%)",
    },
    {
      "scope":"mcs.core.number_ranges",
      "foreground":"hsl(110, 100%, 65%)",
      "font_style":"bold"
    },
    {"scope":"mcs.core.number.byte","foreground":"hsl(350, 100%, 60%)"},
    {"scope":"mcs.core.number.short","foreground":"hsl(295, 100%, 70%)"},
