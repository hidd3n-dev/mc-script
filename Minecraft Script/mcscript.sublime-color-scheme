    {"scope":"mcs.command.a","foreground":"hsl(270, 100%, 85%)"},
    {"scope":"mcs.command.b","foreground":"hsl(25, 100%, 80%)"},
    {"scope":"mcs.command.c","foreground":"hsl(100, 100%, 80%)"},
    {},
  ]
