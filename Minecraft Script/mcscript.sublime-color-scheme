    {"scope":"mcs.declare.equal.singles.numeric","foreground":"hsl(215, 100%, 85%)"},
    {"scope":"mcs.declare.equal.quotes.numeric","foreground":"hsl(25, 100%, 85%)"},
    {"scope":"mcs.declare.equal.name.quote","foreground":"hsl(255, 60%, 80%)"},
    {"scope":"mcs.declare.equal.singles.quote","foreground":"hsl(215, 100%, 85%)"},
    {"scope":"mcs.declare.equal.quotes.quote","foreground":"hsl(25, 100%, 85%)"},
    {"scope":"mcs.declare.equal.name.compound","foreground":"hsl(255, 60%, 80%)"},
    {"scope":"mcs.declare.equal.singles.compound","foreground":"hsl(215, 100%, 85%)"},
    {"scope":"mcs.declare.equal.quotes.compound","foreground":"hsl(25, 100%, 85%)"},
    {},
    {"scope":"mcs.declare.colon.name","foreground":"hsl(325, 100%, 75%)"},
    {"scope":"mcs.declare.colon.singles","foreground":"hsl(150, 90%, 75%)"},
    {"scope":"mcs.declare.colon.quotes","foreground":"hsl(35, 80%, 75%)"},
    {},
    {"scope":"mcs.declare.equal.name","foreground":"hsl(255, 60%, 80%)"},
    {"scope":"mcs.declare.equal.singles","foreground":"hsl(215, 100%, 85%)"},
    {"scope":"mcs.declare.equal.quotes","foreground":"hsl(25, 100%, 85%)"},
    {},
    {},// core
    {
      "scope":"mcs.core.line_cont",
      "foreground":"hsl(50, 100%, 50%)",
      "background":"hsl(60, 65%, 20%)",
      "font_style":"bold"
