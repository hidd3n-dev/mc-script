  "rules":
  [
    {
      "name":"all font styles provided",
      "scope":"unused",
      "foreground":"",
      "background":"",
      "font_style":"bold italic glow underline stippled_underline squiggly_underline"
    },
    {},
    {},// fallback
    {
      "scope":"mcs",
      "foreground":"#ffaaff"
    },
    {},
    {},// remarks
    {
      "scope":"mcs.remark.code",
      "foreground":"hsl(60, 0%, 85%)",
      "background":"hsl(60, 15%, 0%)",
    },
    {
      "scope":"mcs.remark.notice",
      "foreground":"hsl(40, 75%, 65%)",
      "background":"hsl(60, 10%, 30%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.remark.confirm",
      "foreground":"hsl(120, 85%, 50%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.remark.ignore",
      "foreground":"hsl(0, 0%, 40%)",
      "background":"hsl(0, 0%, 5%)",
    },
    {
      "scope":"mcs.remark.raze",
      "foreground":"hsl(355, 70%, 60%)",
      "background":"hsl(0, 100%, 5%)",
      "font_style":"bold"
    },
    {},
    {},// comments
    {
      "scope":"mcs.comment.quad",
      "foreground":"hsl(60, 55%, 70%)",
      "background":"hsl(60, 15%, 30%)",
    },
    {
      "scope":"mcs.comment.triple",
      "foreground":"hsl(120, 35%, 70%)",
    },
    {
      "scope":"mcs.comment.double",
      "foreground":"hsl(205, 35%, 65%)",
    },
    {
      "scope":"mcs.comment.single",
      "foreground":"hsl(240, 2%, 55%)",
    },
    {
      "scope":"mcs.comment.inline",
      "foreground":"hsl(355, 60%, 65%)",
    },
    {},
    {},// errors
    {
      "scope":"mcs.error",
      "foreground":"hsl(0, 0%, 95%)",
      "background":"hsl(355, 65%, 55%)",
    },
    {
      "scope":"mcs.error.spaces",
      "foreground":"hsl(0, 0%, 95%)",
      "background":"hsl(350, 100%, 65%)",
    },
    {},
    {},// utils
    {
      "scope":"mcs.util.arrows",
      "foreground":"hsl(310, 90%, 80%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.remark",
      "foreground":"hsl(355, 100%, 65%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.doubt",
      "foreground":"hsl(25, 100%, 60%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.minusate",
      "foreground":"hsl(350, 100%, 60%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.additionally",
      "foreground":"hsl(205, 100%, 65%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.attention",
      "foreground":"hsl(300, 100%, 75%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.util.including",
      "foreground":"hsl(255, 60%, 80%)",//45, 85%, 55%//255, 50%, 75%
      "font_style":"bold"
    },
    {},
    {},// quotes
    {
      "scope":"mcs.quotes.single",
      "foreground":"hsl(30, 100%, 65%)",
    },{
      "scope":"mcs.quotes.single.body",
      "foreground":"hsl(60, 100%, 75%)",
    },
    {
      "scope":"mcs.quotes",
      "foreground":"hsl(205, 70%, 75%)",//145, 100%, 85%//345, 40%, 65%
    },{
      "scope":"mcs.quotes.body",
      "foreground":"hsl(145, 100%, 85%)",//145, 100%, 85%//205, 70%, 75%
    },
    {
      "scope":"mcs.quotes.escape_chars",
      "foreground":"hsl(335, 100%, 85%)",
    },
    {},
    {},// wraps
    {
      "scope":"mcs.wrap.parentheses.a",
      "foreground":"hsl(30, 100%, 65%)",
    },{
      "scope":"mcs.wrap.parentheses.b",
      "foreground":"hsl(60, 100%, 85%)",
    },
    {
      "scope":"mcs.wrap.brackets.a",
      "foreground":"hsl(340, 100%, 75%)",
    },{
      "scope":"mcs.wrap.brackets.b",
      "foreground":"hsl(95, 100%, 65%)",
    },
    {
      "scope":"mcs.wrap.braces.a",
      "foreground":"hsl(240, 100%, 80%)",
    },{
      "scope":"mcs.wrap.braces.b",
      "foreground":"hsl(30, 100%, 80%)",
    },
    {},
