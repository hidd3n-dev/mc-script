    {
      "scope":"mcs.core.target_selectors",
      "foreground":"hsl(105, 100%, 65%)",
    },
    {
      "scope":"mcs.core.tilde",
      "foreground":"hsl(300, 100%, 75%)",
      "font_style":"bold"
    },
    {
      "scope":"mcs.core.caret",
      "foreground":"hsl(25, 100%, 60%)",
