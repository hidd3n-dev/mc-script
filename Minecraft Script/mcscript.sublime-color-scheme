      "scope":"mcs.macro.arg",
      "foreground":"hsl(300, 100%, 85%)",
      "background":"hsl(240, 25%, 35%)",
    },
    {
      "scope":"mcs.macro.arg.invalid",
      "foreground":"hsl(0, 0%, 95%)",
      "background":"hsl(350, 100%, 65%)",//355, 65%, 55%
    },
    {},
    {},// declarations
    {
      "scope":"mcs.declare.path_separator",
      "foreground":"hsl(335, 100%, 65%)",//45, 85%, 55%//50, 60%, 50%//200, 100%, 60%
      //"background":"hsl(280, 20%, 20%)",
      "font_style":"bold"
    },
    {"scope":"mcs.declare.colon.name.alphabetic","foreground":"hsl(325, 100%, 75%)"},
    {"scope":"mcs.declare.colon.singles.alphabetic","foreground":"hsl(150, 90%, 75%)"},
    {"scope":"mcs.declare.colon.quotes.alphabetic","foreground":"hsl(35, 80%, 75%)"},
    {"scope":"mcs.declare.colon.name.numeric","foreground":"hsl(325, 100%, 75%)"},
    {"scope":"mcs.declare.colon.singles.numeric","foreground":"hsl(150, 90%, 75%)"},
    {"scope":"mcs.declare.colon.quotes.numeric","foreground":"hsl(35, 80%, 75%)"},
    {"scope":"mcs.declare.colon.name.quote","foreground":"hsl(325, 100%, 75%)"},
    {"scope":"mcs.declare.colon.singles.quote","foreground":"hsl(150, 90%, 75%)"},
    {"scope":"mcs.declare.colon.quotes.quote","foreground":"hsl(35, 80%, 75%)"},
    {"scope":"mcs.declare.colon.name.compound","foreground":"hsl(325, 100%, 75%)"},
    {"scope":"mcs.declare.colon.singles.compound","foreground":"hsl(150, 90%, 75%)"},
    {"scope":"mcs.declare.colon.quotes.compound","foreground":"hsl(35, 80%, 75%)"},
    {},
    {"scope":"mcs.declare.equal.name.alphabetic","foreground":"hsl(255, 60%, 80%)"},
    {"scope":"mcs.declare.equal.singles.alphabetic","foreground":"hsl(215, 100%, 85%)"},
    {"scope":"mcs.declare.equal.quotes.alphabetic","foreground":"hsl(25, 100%, 85%)"},
