
## from: ``https://minecraft.wiki/w/Commands/execute#More_examples``

execute as @a if data entity @s Inventory[{Slot:0b}].tag.Enchantments[{id:"minecraft:efficiency"}] run tp @s 0 64 0
execute as @a at @s anchored eyes run particle smoke ^ ^ ^3
execute as @e[type=pig] at @s store success entity @s Saddle byte 1 if entity @p[distance=..5]
execute as @a at @s if block ~ ~ ~ water run say "My feet are soaked!"
execute as @a unless score @s test = @s test run say "Score is reset"
execute at @p as @e[type=skeleton,distance=..3] run data merge entity @s {Motion:[0.0,2.0,0.0]}
execute as @e[type=zombie] unless data entity @s ArmorItems[3].id run kill @s
execute as @a at @s store result score @s nearbyRedSheep if entity @e[type=sheep,nbt={Color:14},distance=..20]


------------------------------------------------------------------------------------------------------------------------


execute at @a run playsound minecraft:entity.evoker.prepare_summon master @s ~ ~50 ~ 50 1.7

execute as @a at @s as @e[type=!player,limit=10,sort=random] run tp ^ ^ ^10


------------------------------------------------------------------------------------------------------------------------


advancement revoke @s only homeward_bone:used_homeward_bone

execute unless data entity @s respawn run playsound minecraft:block.note_block.cow_bell master @s ~ ~50 ~ 50 0.7
execute unless data entity @s respawn run return run tellraw @s {"text": " No HOME to warp to!", "color": "#ddcc55"}

data modify storage homeward_bone:st warp.x set from entity @s respawn.pos[0]
data modify storage homeward_bone:st warp.y set from entity @s respawn.pos[1]
data modify storage homeward_bone:st warp.z set from entity @s respawn.pos[2]
data modify storage homeward_bone:st warp.d set from entity @s respawn.dimension
data modify storage homeward_bone:st warp.yaw set from entity @s Rotation[0]
data modify storage homeward_bone:st warp.pitch set from entity @s Rotation[1]

execute as @s run function homeward_bone:f1 with storage homeward_bone:st warp

execute at @s run particle minecraft:poof ~ ~1.2 ~ .5 .5 .5 0 15 force @s


------------------------------------------------------------------------------------------------------------------------


give @s minecraft:bone[\
  enchantment_glint_override=true,\
  custom_data={homeward_bone:1},\
  custom_name={"color":"#eebb55","italic":false,"text":"Homeward Bone"},\
  lore=[\
    [{"text": "A mysterious bone", "color": "#bbbbbb", "italic": false}],\
    [{"text": "to take you home...", "color": "#bbbbbb", "italic": false}]\
  ],\
  consumable={\
    consume_seconds:2.5,animation:"brush",sound:"block.beacon.power_select",has_consume_particles:false,\
    on_consume_effects:[{type:"minecraft:play_sound",sound:"entity.evoker.prepare_summon"}]\
  },\
  use_cooldown={seconds:2.5,cooldown_group:"homeward_bone:a"}\
] 3


------------------------------------------------------------------------------------------------------------------------


$item modify entity @s weapon.mainhand {\
  function:"minecraft:set_components",\
  components:{\
    "minecraft:consumable":{consume_seconds:999,animation:"brush",has_consume_particles:false},\
    "minecraft:custom_data":{warp_compasses:1},\
    "minecraft:custom_name":[\
      {"color":"#ee77cc","italic":false,"text":"Warp Compass "},\
      {"color":"$(color)","italic":false,"text":"[$(x), $(y), $(z)]"}\
    ],\
    "minecraft:lore":[\
      [{"text": "Travel whence it points", "color": "#bbbbbb", "italic": false}],\
      [\
        {"text": "by spending an ", "color": "#bbbbbb", "italic": false},\
        {"text": "Emerald", "color": "#2DE56B", "italic": false}\
      ]\
    ]}}


------------------------------------------------------------------------------------------------------------------------


